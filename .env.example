# LeadForge Environment Configuration
# Copy to .env and fill in your values

# --- Ruflo ---
GITHUB_TOKEN=

# --- API Keys ---
DEEPSEEK_API_KEY=
ZEROBOUNCE_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=

# --- CRM ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
PIPEDRIVE_API_TOKEN=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/leadforge

# --- Temporal ---
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=leadforge

# --- Gmail ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# --- LLM ---
OPENROUTER_API_KEY=
LLM_MODEL=deepseek-chat
LLM_PROVIDER=openrouter
